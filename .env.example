# Public Supabase values. These are safe to expose to the browser when RLS is configured correctly.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Server-only secrets.
# Do not put production secrets in local files. Configure these in Vercel Environment Variables instead.
# OPENAI_API_KEY="your-development-only-openai-key"
# SUPABASE_SERVICE_ROLE_KEY="production-only-in-vercel"
# TRENDING_BOT_SECRET="production-only-in-vercel"
# TRENDING_BOT_USER_ID="auth-user-id-for-trending-bot"
